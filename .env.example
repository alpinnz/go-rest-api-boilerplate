#############################################
# ============ APP CONFIG ==================
#############################################
# APP_ENV defines the application environment
# options: development | staging | production
APP_ENV=development

# APP_DEFAULT_LOCALE sets default language (id/en)
APP_DEFAULT_LOCALE=id

#############################################
# ============ SERVER CONFIG ===============
#############################################
# SERVER_ADDRESS defines the host/port for the HTTP server
# example: ":3000" (listen on all hosts at port 3000)
SERVER_ADDRESS=:3000

#############################################
# ============ POSTGRES CONFIG =============
#############################################
# PostgreSQL database configuration
# Make sure the DB is running and accessible
DB_PG_HOST=localhost
DB_PG_PORT=5432
DB_PG_USER=postgres
DB_PG_PASS=postgres
DB_PG_NAME=go_rest_api_boilerplate

#############################################
# ============ AUTH CONFIG =================
#############################################
# Generate secrets using:
#   openssl rand -hex 32
# Keep these values safe (DO NOT commit to public repos)
AUTH_ACCESS_TOKEN_SECRET=your_access_token_secret_here
AUTH_REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
AUTH_PASSWORD_SECRET=your_password_secret_here

#############################################
# ============ SMTP CONFIG =================
#############################################
# SMTP configuration for sending emails
# If using Gmail, you must use an App Password (not your real password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=your_email@gmail.com
